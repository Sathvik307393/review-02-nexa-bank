# Apex Banking Portal - Environment Configuration
# Copy this file to .env and update values as needed

# ===== ENVIRONMENT =====
NODE_ENV=development

# ===== DATABASE =====
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=SecurePass123!@
DB_NAME=apex_bank
DB_SSL=false

# ===== AUTHENTICATION =====
JWT_SECRET=apex_banking_super_secret_cryptographic_key_9988
JWT_EXPIRY=2h

# ===== FILE UPLOADS =====
UPLOAD_DIR=./uploads
JSON_DB_PATH=./database.json

# ===== AZURE CONFIGURATION (Optional) =====
AZURE_STORAGE_CONNECTION_STRING=
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=

# ===== EMAIL SERVICE (Optional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM_NAME=Apex Bank
SMTP_FROM_EMAIL=security@apexbank.com

# ===== SERVICE URLs (For local Docker) =====
AUTH_SERVICE_URL=http://auth:3001
USER_SERVICE_URL=http://user:3002
TRANSACTION_SERVICE_URL=http://transactions:3003
KYC_SERVICE_URL=http://kyc:3004
AUDIT_SERVICE_URL=http://audit:3006
ADMIN_SERVICE_URL=http://admin:3007
DOC_PROCESSOR_URL=http://doc-processor:3005

# ===== CORS CONFIGURATION =====
CORS_ORIGIN=http://localhost:3000

# ===== LOGGING =====
LOG_LEVEL=info
